# AgriNext Gen — Environment Variables
# Copy to .env and fill in values. Never commit .env.
#
# PRODUCTION NOTE:
# Set these same variables in your deployment platform (Vercel, Netlify, etc.).
# The app will refuse to start in production if required variables are missing.

# Supabase (required — app will not start without these)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...
# VITE_SUPABASE_ANON_KEY is the same value as PUBLISHABLE_KEY (Supabase anon key).
# Both are accepted; set at least one. If only one is set, the other is used as fallback.
VITE_SUPABASE_ANON_KEY=eyJ...

# Feature flags
# IMPORTANT: Set to "false" or leave unset for production builds.
# Setting to "true" enables /dev-console and the dev role switcher.
VITE_DEV_TOOLS_ENABLED=false
VITE_ENABLE_PRICE_FORECASTS=false

# Optional (Maps, TTS — features degrade gracefully if unset)
VITE_GOOGLE_MAPS_API_KEY=
